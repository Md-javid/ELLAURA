# ═══════════════════════════════════════════════════════════
# Ellaura — Environment Variables
# ═══════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values
# 3. NEVER commit .env to git
#
# The app works in DEMO MODE if these are left as placeholders.
# ═══════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────
# Get these from: https://app.supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Stripe ────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com → Developers → API Keys
# Use TEST keys during development; switch to LIVE keys before go-live
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Secret key — used server-side only (Supabase Edge Function)
# NEVER expose this in the frontend bundle
# Set via: supabase secrets set STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# ── Admin ─────────────────────────────────────────────────
# 6-digit PIN for the /admin dashboard — CHANGE this to something secure!
VITE_ADMIN_PIN=000000

# ── AI Stylist (OpenAI) ───────────────────────────────────
# Set server-side only: supabase secrets set OPENAI_API_KEY=sk-...
# NEVER prefix with VITE_ — that would expose it in the browser bundle

# ── App ───────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
