# -----------------------------------------------------------
# Ellaura — Environment Variables
# -----------------------------------------------------------
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values
# 3. NEVER commit .env to git — it is in .gitignore
#
# The app works in DEMO MODE if Supabase variables are left as placeholders.
# -----------------------------------------------------------

# -- Supabase --------------------------------------------------
# https://app.supabase.com ? your project ? Settings ? API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-public-key-here

# -- Razorpay --------------------------------------------------
# Use rzp_test_... during development; switch to rzp_live_... before launch
# https://dashboard.razorpay.com ? Settings ? API Keys
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX

# -- Admin credentials -----------------------------------------
# These seed the first admin account on first login.
# Change both before deploying!
VITE_ADMIN_EMAIL=admin@ellaura.in
VITE_ADMIN_PASSWORD=ChangeMe@2026!

# -- WhatsApp order notifications ------------------------------
# Country code + number with no spaces or +, e.g. 919876543210
VITE_WHATSAPP_NUMBER=919XXXXXXXXX

# -- Google Sheets order sync (optional) -----------------------
# Deploy a Google Apps Script as a Web App and paste the URL here.
# Leave blank to skip.
VITE_SHEETS_WEBHOOK_URL=

# -- App URL ---------------------------------------------------
VITE_APP_URL=https://ellaura.in
